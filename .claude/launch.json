{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "gazette",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["-e", "const p=require('path'),f=require('fs'),h=require('http');const d='/Users/headroom/Desktop/claude/gazette/';const m={'.html':'text/html','.png':'image/png','.jpg':'image/jpeg','.css':'text/css','.js':'application/javascript'};h.createServer((q,r)=>{let u=q.url==='/'?'/index.html':q.url;let fp=p.join(d,u);let ext=p.extname(fp);f.access(fp,f.constants.R_OK,(e)=>{if(e){r.writeHead(404);r.end('Not found');return}r.writeHead(200,{'Content-Type':m[ext]||'application/octet-stream'});f.createReadStream(fp).pipe(r)})}).listen(8090)"],
      "port": 8090
    }
  ]
}
